<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="MyGetUmbracoPreRelease" value="https://www.myget.org/F/umbracoprereleases/api/v3/index.json" />
    <add key="MyGetUmbracoCloudBundle" value="https://www.myget.org/F/uc-bundle/api/v3/index.json" />
    <add key="Umbraco_Internal" value="https://pkgs.dev.azure.com/umbraco/_packaging/Umbraco_Internal/nuget/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="Umbraco_Internal" >
    <package pattern="JamUmbPac" />
    </packageSource>
  </packageSourceMapping>
  
</configuration>
